{
  "_comment": "中文学术论文格式 — 华东师范大学硕士论文规范",
  "page": {
    "top_cm": 3.0, "bottom_cm": 2.5,
    "left_cm": 3.2, "right_cm": 2.5
  },
  "body": {
    "font": "SimSun", "font_en": "Times New Roman",
    "size_pt": 12, "line_spacing_pt": 25,
    "space_before_pt": 0, "space_after_pt": 0,
    "first_line_indent_chars": 2
  },
  "headings": {
    "h1": {
      "font": "SimHei", "font_en": "Times New Roman",
      "size_pt": 16, "bold": true, "color": "000000",
      "align": "center",
      "space_before_pt": 24, "space_after_pt": 18
    },
    "h2": {
      "font": "SimHei", "font_en": "Times New Roman",
      "size_pt": 14, "bold": true, "color": "000000",
      "align": "left",
      "space_before_pt": 18, "space_after_pt": 12
    },
    "h3": {
      "font": "SimHei", "font_en": "Times New Roman",
      "size_pt": 12, "bold": true, "color": "000000",
      "align": "left",
      "space_before_pt": 12, "space_after_pt": 6
    },
    "h4": {
      "font": "SimHei", "font_en": "Times New Roman",
      "size_pt": 12, "bold": false, "color": "000000",
      "align": "left",
      "space_before_pt": 10, "space_after_pt": 4
    }
  },
  "code_block": {
    "font": "Courier New", "size_pt": 10,
    "bg_color": "F5F5F5"
  },
  "blockquote": {
    "font": "SimSun", "font_en": "Times New Roman",
    "size_pt": 12, "color": "333333",
    "left_indent_cm": 1.0
  },
  "table": {
    "font": "SimSun", "font_en": "Times New Roman",
    "size_pt": 10.5,
    "header_bold": true,
    "header_bg_color": null,
    "border_mode": "mckinsey",
    "rule_color": "000000",
    "border_color": "000000",
    "cell_padding_pt": 4,
    "space_before_pt": 6,
    "space_after_pt": 6
  }
}
