    "hold":        { "fill": "#666666", "stroke": "#888888", "note": "中性 / 观察" },
    "speculative": { "fill": "#003366", "stroke": "#1A4D99", "note": "外部对比方 / 竞争对手" },
    "value":       { "fill": "#1A1A1A", "stroke": "#3D3D3D", "note": "权威 / 结论性陈述" }
  },
  "edge": {
