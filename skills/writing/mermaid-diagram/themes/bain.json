    "layer2": { "fill": "#2D2D2D", "stroke": "#4D4D4D", "note": "中间层" },
    "layer3": { "fill": "#3D3D3D", "stroke": "#5D5D5D", "note": "应用层 / 下游" }
  },
  "node": {
