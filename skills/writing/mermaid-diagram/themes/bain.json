    "layer3": { "fill": "#444444", "stroke": "#666666", "note": "深灰 — 支撑节点" }
  },
  "semantic": {
    "alert":       { "fill": "#CC0000", "stroke": "#990000", "note": "风险 / 问题（Bain Red）" },
