    "layer3": { "fill": "#227A30", "stroke": "#2E8040" }
  },
  "semantic": {
    "alert":       { "fill": "#D82216", "stroke": "#F04030", "note": "预警 / 高风险" },
    "opportunity": { "fill": "#21BF61", "stroke": "#33CC77", "note": "机会 / 增长" },
    "hold":        { "fill": "#696969", "stroke": "#888888", "note": "中性 / 观察" },
    "speculative": { "fill": "#0C2B15", "stroke": "#164A20", "note": "深度价值 / 长期" },
