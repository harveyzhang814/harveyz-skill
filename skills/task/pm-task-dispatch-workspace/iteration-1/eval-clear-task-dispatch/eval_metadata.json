{
  "eval_id": 1,
  "eval_name": "clear-task-dispatch",
  "prompt": "Harvey 说：派一个任务给 coding-master，让他用 Python 写一个命令行工具，读取 CSV 文件并输出统计摘要（行数、列名、每列的均值/最大/最小）。优先级 medium，项目是 data-tools。任务ID 用 T100。",
  "assertions": [
    {
      "id": "task-folder-created",
      "text": "在 ~/Projects/project-management/tasks/T100/ 下创建了任务文件夹",
      "check": "file_exists: ~/Projects/project-management/tasks/T100/task.md"
    },
    {
      "id": "frontmatter-id",
      "text": "task.md frontmatter 包含正确的 id: T100",
      "check": "file_contains: tasks/T100/task.md, id: T100"
    },
    {
      "id": "frontmatter-assignee",
      "text": "task.md frontmatter 包含 assignee（coding-master）",
      "check": "file_contains: tasks/T100/task.md, coding-master"
    },
    {
      "id": "frontmatter-status-open",
      "text": "task.md frontmatter status 为 open",
      "check": "file_contains: tasks/T100/task.md, status: open"
    },
    {
      "id": "has-main-goal",
      "text": "task.md 包含 ## 主要目标 章节",
      "check": "file_contains: tasks/T100/task.md, ## 主要目标"
    },
    {
      "id": "has-eval-criteria",
      "text": "task.md 包含 ## 评估标准 章节",
      "check": "file_contains: tasks/T100/task.md, ## 评估标准"
    },
    {
      "id": "has-constraints",
      "text": "task.md 包含 ## 关键约束 章节",
      "check": "file_contains: tasks/T100/task.md, ## 关键约束"
    }
  ]
}
