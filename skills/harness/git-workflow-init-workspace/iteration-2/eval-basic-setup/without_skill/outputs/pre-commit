#!/bin/sh
# pre-commit: block direct commits to protected branches
# Generated from workflow-config.yml (branches.protected)

branch=$(git symbolic-ref --short HEAD 2>/dev/null)

if [ "$branch" = "main" ] || [ "$branch" = "staging" ]; then
  echo "ERROR: Direct commits to '$branch' are not allowed."
  echo "Use a feature/fix/chore/doc branch and merge via pull request."
  exit 1
fi

exit 0
