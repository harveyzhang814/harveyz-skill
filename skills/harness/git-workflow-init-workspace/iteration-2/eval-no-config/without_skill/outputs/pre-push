#!/bin/bash
# pre-push hook — prevent force-pushing to protected branches
# Generated by: git workflow init (default config, no workflow-config.yml found)

PROTECTED_BRANCHES="main staging master"
REMOTE="$1"
URL="$2"

while read local_ref local_sha remote_ref remote_sha; do
  # Extract branch name from remote ref
  BRANCH=$(echo "$remote_ref" | sed 's|refs/heads/||')

  for protected in $PROTECTED_BRANCHES; do
    if [ "$BRANCH" = "$protected" ]; then
      # Check if this is a force push (local sha is not a descendant of remote sha)
      if [ "$remote_sha" != "0000000000000000000000000000000000000000" ]; then
        if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
          echo ""
          echo "ERROR: Force push to '$BRANCH' is not allowed."
          echo ""
          echo "Protected branches must only move forward. If you need to revert,"
          echo "create a revert commit instead."
          echo ""
          exit 1
        fi
      fi

      # Warn if pushing directly to protected branch (non-PR workflow)
      echo "WARNING: Pushing directly to '$BRANCH'. Consider using a PR workflow."
    fi
  done
done

exit 0
