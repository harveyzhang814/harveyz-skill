#!/bin/bash
# pre-commit hook — branch protection
# Blocks direct commits to protected branches (main, staging, master)
# Generated by: git workflow init (default config, no workflow-config.yml found)

PROTECTED_BRANCHES="main staging master"
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

for branch in $PROTECTED_BRANCHES; do
  if [ "$CURRENT_BRANCH" = "$branch" ]; then
    echo ""
    echo "ERROR: Direct commits to '$branch' are not allowed."
    echo ""
    echo "Please use a feature/fix/chore/doc branch and merge via pull request:"
    echo "  git checkout -b feature/my-change"
    echo "  # ... make changes ..."
    echo "  git push origin feature/my-change"
    echo ""
    exit 1
  fi
done

exit 0
