{
  "toolBundleMeta": {
    "shell-tools": "终端工具（p-launch 本地仓库管理器 + todo-tool 任务管理器）",
    "tools": "开发者 OS 工具（hub — 项目管理 + git 状态 + 任务跟踪）"
  },
  "tools": [
    {
      "name": "p-launch",
      "bundle": "shell-tools"
    },
    {
      "name": "todo-tool",
      "bundle": "shell-tools"
    },
    {
      "name": "hub",
      "path": "tools/hub",
      "bundle": "tools"
    }
  ],
  "bundleMeta": {
    "research": "研究工具（extract-url + learn-video + extract-vision）",
    "creative": "创意工具（capture-todo + capture-insight）",
    "coding": "程序工具（init-workflow + setup-debug + dispatch-task + close-task）",
    "writing": "写作工具（forge-doc + draw-diagram + manage-docs + manage-dir + migrate-spec）",
    "design": "设计工具（scout-brand + build-style + sync-design）",
    "meta": "元操作工具（analyze-skill + clean-git + archive-skill + dedup-skill + contribute-skill + publish-skill + release-project + runby-opencode）"
  },
  "skills": [
    { "path": "research/extract-url",           "bundle": "research", "global": true  },
    { "path": "research/extract-vision",        "bundle": "research", "global": true  },
    { "path": "research/learn-video",           "bundle": "research", "global": true  },
    { "path": "creative/capture-todo",          "bundle": "creative", "global": true  },
    { "path": "creative/capture-insight",       "bundle": "creative", "global": true  },
    { "path": "coding/init-workflow",           "bundle": "coding",   "global": true  },
    { "path": "coding/setup-debug",             "bundle": "coding"                    },
    { "path": "coding/dispatch-task",           "bundle": "coding",   "global": true  },
    { "path": "coding/close-task",              "bundle": "coding",   "global": true  },
    { "path": "writing/forge-doc",              "bundle": "writing",  "global": true  },
    { "path": "writing/draw-diagram",           "bundle": "writing",  "global": true  },
    { "path": "writing/manage-docs",            "bundle": "writing"                   },
    { "path": "writing/manage-dir",             "bundle": "writing"                   },
    { "path": "writing/migrate-spec",           "bundle": "writing"                   },
    { "path": "design/scout-brand",             "bundle": "design"                    },
    { "path": "design/build-style",             "bundle": "design"                    },
    { "path": "design/sync-design",             "bundle": "design"                    },
    { "path": "meta/analyze-skill",             "bundle": "meta"                      },
    { "path": "meta/clean-git",                 "bundle": "meta",     "global": true  },
    { "path": "meta/archive-skill",             "bundle": "meta"                      },
    { "path": "meta/dedup-skill",               "bundle": "meta"                      },
    { "path": "meta/contribute-skill",          "bundle": "meta"                      },
    { "path": "meta/publish-skill",             "bundle": "meta"                      },
    { "path": "meta/runby-opencode",            "bundle": "meta"                      },
    { "path": "meta/release-project",           "bundle": "meta",     "global": true  }
  ],
  "hooks": [
    {
      "name": "check-similar-branch",
      "description": "用 LLM 语义分析检测相似分支",
      "path": "hooks/check-similar-branch",
      "event": "PreToolUse",
      "matcher": "Bash",
      "timeout": 60,
      "statusMessage": "检查相似分支..."
    }
  ],
  "renames": [
    {
      "from": "url-extract",
      "to": "extract-url"
    },
    {
      "from": "vision-extract",
      "to": "extract-vision"
    },
    {
      "from": "youtube-learner",
      "to": "learn-video"
    },
    {
      "from": "add-todo",
      "to": "capture-todo"
    },
    {
      "from": "insight",
      "to": "capture-insight"
    },
    {
      "from": "git-workflow-init",
      "to": "init-workflow"
    },
    {
      "from": "full-stack-debug-env",
      "to": "setup-debug"
    },
    {
      "from": "pm-task-dispatch",
      "to": "dispatch-task"
    },
    {
      "from": "task-close",
      "to": "close-task"
    },
    {
      "from": "doc-forge",
      "to": "forge-doc"
    },
    {
      "from": "diagram",
      "to": "draw-diagram"
    },
    {
      "from": "diataxis-docs",
      "to": "manage-docs"
    },
    {
      "from": "dir-manage",
      "to": "manage-dir"
    },
    {
      "from": "migrate-specs",
      "to": "migrate-spec"
    },
    {
      "from": "brand-scout",
      "to": "scout-brand"
    },
    {
      "from": "style-build",
      "to": "build-style"
    },
    {
      "from": "sync-design-html",
      "to": "sync-design"
    },
    {
      "from": "git-cleanup",
      "to": "clean-git"
    },
    {
      "from": "skill-analyzer",
      "to": "analyze-skill"
    },
    {
      "from": "skill-publish",
      "to": "publish-skill"
    },
    {
      "from": "opencode-runner",
      "to": "runby-opencode"
    },
    {
      "from": "project-release",
      "to": "release-project"
    }
  ]
}
