    },
    {
      "from": "git-cleanup",
      "to": "clean-git"
    },
    {
      "from": "skill-analyzer",
      "to": "analyze-skill"
    },
    {
      "from": "skill-publish",
      "to": "publish-skill"
    },
    {
      "from": "opencode-runner",
