{
  "toolBundleMeta": {
    "shell-tools": "终端工具（p-launch 本地仓库管理器）"
  },
  "tools": [
    {
      "name": "p-launch",
      "bundle": "shell-tools"
    }
  ],
  "bundleMeta": {
    "research":  "研究工具（article-fetcher + url-extract + youtube-learner + vision-extract）",
    "creative":  "创意工具（add-todo + insight）",
    "coding":    "程序工具（git-workflow-init + full-stack-debug-env + pm-task-dispatch + task-close）",
    "writing":   "写作工具（doc-forge + diagram + diataxis-docs + dir-manage + migrate-specs）",
    "design":    "设计工具（brand-scout + style-build + sync-design-html）",
    "meta":      "元操作工具（skill-analyzer + git-cleanup + contribute-skill + skill-publish + npm-release）"
  },
  "skills": [
    { "path": "data-extraction/article-fetcher",       "bundle": "research" },
    { "path": "data-extraction/url-extract",           "bundle": "research" },
    { "path": "data-extraction/vision-extract",        "bundle": "research" },
    { "path": "data-extraction/youtube-learner",       "bundle": "research" },
    { "path": "workflow/add-todo",                     "bundle": "creative" },
    { "path": "writing/insight",                       "bundle": "creative" },
    { "path": "harness/git-workflow-init",             "bundle": "coding" },
    { "path": "harness/full-stack-debug-env",          "bundle": "coding" },
    { "path": "task/pm-task-dispatch",                 "bundle": "coding" },
    { "path": "task/task-close",                       "bundle": "coding" },
    { "path": "writing/doc-forge",                     "bundle": "writing" },
    { "path": "writing/diagram",                       "bundle": "writing" },
    { "path": "harness/diataxis-docs",                 "bundle": "writing" },
    { "path": "harness/dir-manage",                    "bundle": "writing" },
    { "path": "harness/migrate-specs",                 "bundle": "writing" },
    { "path": "writing/brand-scout",                   "bundle": "design" },
    { "path": "writing/style-build",                   "bundle": "design" },
    { "path": "design/sync-design-html",               "bundle": "design" },
    { "path": "analysis/skill-analyzer",               "bundle": "meta" },
    { "path": "analysis/git-cleanup",                  "bundle": "meta" },
    { "path": "meta/contribute-skill",                 "bundle": "meta" },
    { "path": "meta/skill-publish",                    "bundle": "meta" },
    { "path": "meta/npm-release",                      "bundle": "meta" }
  ],
  "hooks": [
    {
      "name": "check-similar-branch",
      "description": "用 LLM 语义分析检测相似分支",
      "path": "hooks/check-similar-branch",
      "event": "PreToolUse",
      "matcher": "Bash",
      "timeout": 60,
      "statusMessage": "检查相似分支..."
    }
  ]
}
