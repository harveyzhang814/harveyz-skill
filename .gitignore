# 默认忽略所有
*

# 保留根目录文件
!.gitignore
!README.md
!CHANGELOG.md
!CLAUDE.md
!TODO.md
!package.json
!package-lock.json
!bundles.json
!skills-index.json
!.npmignore
!workflow-config.yml

# 保留 git hooks
!.githooks/
!.githooks/**

# 保留 npm 包目录
!bin/
!bin/**
!lib/
!lib/**

# 保留插件清单
!.claude-plugin/
!.claude-plugin/**

# 保留脚本
!scripts/
!scripts/**

# 保留技能目录
!skills/
!skills/**/
!skills/**/*

# 保留工具目录
!tools/
!tools/**/
!tools/**/*

# 保留 hooks 目录
!hooks/
!hooks/**/
!hooks/**/*

# 保留文档目录
!docs/
!docs/**/
!docs/**/*

# 保留知识库目录
!knowledge/
!knowledge/**/
!knowledge/**/*

# 保留测试目录
!tests/
!tests/**



# 排除 eval workspace
**/*-workspace/

# 排除构建产物
node_modules/
.DS_Store
*.pyc
__pycache__/
*.log

# 保留 .hskill 项目本地数据目录
!.hskill/
!.hskill/**/
!.hskill/**/*
.hskill/**/.DS_Store

# .claude 配置文件
!.claude/
!.claude/**
.claude/*.local.md
.claude/settings.local.json
.claude/skills/
.claude/**/.DS_Store
.claude/.DS_Store
.gstack/
